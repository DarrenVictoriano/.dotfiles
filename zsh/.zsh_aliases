#!/bin/bash

alias pq='parquet-tools'
alias ai='conda activate open-webui; cd /Users/dxv1220/code/open-webui/backend; git checkout change_port; bash start.sh'
alias vim='nvim'
alias gal='gcloud auth login'
alias gaal='gcloud auth application-default login'
alias compile_this='mcs -reference:API/Dexcom.Agent.Core.dll,API/Dexcom.Receiver.Secure.dll,Authenticators/BouncyCastle.Crypto.dll,Authenticators/BouncyCastleAuthenticator.dll,HelloG7/packages/Newtonsoft.Json.13.0.1/lib/netstandard2.0/Newtonsoft.Json.dll,/Library/Frameworks/Mono.framework/Versions/Current/lib/mono/4.5/System.Data.dll,/Library/Frameworks/Mono.framework/Versions/Current/lib/mono/4.8-api/Facades/netstandard.dll HelloG7/Program.cs'
alias generatebin='conda activate py38_dap; python /Users/dxv1220/code/script/main.py generate-bin'
alias icat='kitty icat'
alias kvd='kubevpn disconnect --all'
alias kswitchcontext='kubectl config use-context $(kubectl config get-contexts -o name | fzf)'
alias sync-notes='pushd /Users/dxv1220/code/darren/script/ > /dev/null; poetry run python sync_notes.py; echo "sync done!"; popd > /dev/null'
